{
  "name": "@ai-first/api-starter",
  "version": "0.1.0",
  "description": "AI-First Framework API Starter - 开箱即用的 API 开发套件",
  "type": "module",
  "bin": {
    "ai-first-codegen": "./dist/codegen.js"
  },
  "scripts": {
    "build": "tsup bin/codegen.ts --format esm --dts --outDir dist"
  },
  "files": [
    "dist"
  ],
  "exports": {
    "./codegen": "./dist/codegen.js"
  },
  "keywords": [
    "ai-first",
    "api",
    "starter",
    "express",
    "typescript",
    "codegen"
  ],
  "dependencies": {
    "@ai-first/core": "workspace:*",
    "@ai-first/di": "workspace:*",
    "@ai-first/nextjs": "workspace:*",
    "@ai-first/orm": "workspace:*",
    "@ai-first/validation": "workspace:*",
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "reflect-metadata": "^0.2.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}
