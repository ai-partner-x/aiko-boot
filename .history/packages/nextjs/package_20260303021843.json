{
  "name": "@ai-first/nextjs",
  "version": "0.1.0",
  "description": "AI-First Framework - Next.js adapter with Spring Boot style API definitions",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./client-lite": {
      "import": "./dist/client-lite.js",
      "types": "./dist/client-lite.d.ts"
    }
  },
  "bin": {
    "ai-first-nextjs-setup": "./scripts/postinstall.cjs"
  },
  "files": [
    "dist",
    "scripts"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "postinstall": "node scripts/postinstall.cjs"
  },
  "dependencies": {
    "reflect-metadata": "^0.2.1",
    "@ai-first/core": "workspace:*",
    "@ai-first/di": "workspace:*"
  },
  "peerDependencies": {
    "next": "^14.0.0 || ^15.0.0 || ^16.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "next": "^14.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "ai-first",
    "nextjs",
    "spring-boot",
    "rest-api",
    "controller",
    "typescript"
  ]
}
