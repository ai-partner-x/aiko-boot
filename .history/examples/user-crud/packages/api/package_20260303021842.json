{
  "name": "@user-crud/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./client": {
      "import": "./dist/client/index.ts",
      "types": "./dist/client/index.ts"
    }
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsx scripts/generate-api-client.ts && tsup src/server.ts --format esm --dts",
    "start": "node dist/server.js",
    "lint": "eslint src"
  },
  "dependencies": {
    "@ai-first/core": "workspace:*",
    "@ai-first/di": "workspace:*",
    "@ai-first/nextjs": "workspace:*",
    "@ai-first/orm": "workspace:*",
    "@ai-first/validation": "workspace:*",
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "pg": "^8.13.0",
    "reflect-metadata": "^0.2.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
