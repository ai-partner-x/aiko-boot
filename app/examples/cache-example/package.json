{
  "name": "@app/cache-example",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.11.0"
  },
  "scripts": {
    "dev": "node --import @swc-node/register/esm-register --watch src/index.ts",
    "start": "node --import @swc-node/register/esm-register src/index.ts",
    "build": "tsup src/index.ts --format esm --dts --outDir dist",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-first/cache": "workspace:*",
    "reflect-metadata": "^0.2.1"
  },
  "devDependencies": {
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.18",
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
