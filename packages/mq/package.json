{
  "name": "@ai-first/mq",
  "version": "0.1.0",
  "description": "AI-First Framework - MQ with Spring Boot style decorators (RabbitMQ)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "example": "tsx examples/mq-publish-consume.ts",
    "example:simple": "tsx examples/simple-mq-example.ts"
  },
  "dependencies": {
    "amqplib": "^0.10.4",
    "reflect-metadata": "^0.2.1",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.8",
    "@types/uuid": "^10.0.0",
    "tslib": "^2.8.1",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "ai-first",
    "mq",
    "rabbitmq",
    "spring-boot",
    "decorator",
    "typescript"
  ]
}
