{
  "name": "@ai-first/core",
  "version": "0.1.0",
  "description": "AI-First Framework - Core decorators and metadata system",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "reflect-metadata": "^0.2.1",
    "@ai-first/di": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "ai-first",
    "decorator",
    "metadata",
    "ddd",
    "typescript"
  ]
}
